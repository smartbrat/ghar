{
  "type": "module",
  "scripts": {
    "build:tailwind": "tailwindcss -i ./src/tailwind.css -o ./dist/tailwind.css --minify",
    "watch:tailwind": "tailwindcss -i ./src/tailwind.css -o ./dist/tailwind.css --watch",
    "build:styles": "esbuild styles.css --minify --outfile=dist/styles.min.css && esbuild styles4.css --minify --outfile=dist/styles4.min.css",
    "build:js": "esbuild main.js --minify --outfile=dist/main.min.js",
    "build": "npm run build:tailwind && npm run build:styles && npm run build:js"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "esbuild": "^0.28.0",
    "tailwindcss": "^3.4.19"
  }
}
