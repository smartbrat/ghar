{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'No build needed — dist/ is pre-built and committed.'",
  "installCommand": "echo 'No install needed for static deploy.'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/design/architecture", "destination": "/design-architecture" },
    { "source": "/design/partner-kit",  "destination": "/design-partner-kit" },
    { "source": "/design/series",       "destination": "/design-architecture" },
    { "source": "/design/interiors",    "destination": "/design-architecture" },
    { "source": "/design/spaces",       "destination": "/design-architecture" },
    { "source": "/design/designers",    "destination": "/design-architecture" },
    { "source": "/design/vastu",        "destination": "/design-architecture" },
    { "source": "/design/guides",       "destination": "/design-architecture" },
    { "source": "/design/:slug",        "destination": "/design-article" },
    { "source": "/for-brands",           "destination": "/for-brands" },
    { "source": "/brands",               "destination": "/brands" }
  ],
  "headers": [
    {
      "source": "/dist/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    },
    {
      "source": "/brand_assets/(.*)\\.(webp|png|jpg|jpeg|svg|avif)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
